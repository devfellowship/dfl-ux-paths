{
  "name": "@devfellowship/ux-paths-app",
  "private": true,
  "version": "0.1.0",
  "description": "ux-paths (caminhos de UX) — multi-use-case UI-flow viewer/comparator. Consumes .dfl-ux-paths/flows.json.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 4173",
    "lint": "tsc --noEmit",
    "server": "node server/index.mjs",
    "start": "node server/index.mjs",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@devfellowship/components": "^3.0.0",
    "@xyflow/react": "^12.3.6",
    "express": "^5.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/express": "^5.0.0",
    "@types/node": "^22.5.5",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react-swc": "^4.0.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.0",
    "vite": "^8.0.13"
  },
  "engines": {
    "node": ">=20"
  }
}
