{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/devfellowship/dfl-ux-paths/main/schema/v1.json",
  "title": "DFL UX Paths v1",
  "description": "Versioned per-app user-flow JSON schema for migration-gap analysis and dead-code detection.",
  "type": "object",
  "required": ["schema_version", "app_id", "app_version", "screens", "flows"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0",
      "description": "Version of the dfl-ux-paths schema this file conforms to."
    },
    "app_id": {
      "type": "string",
      "minLength": 1,
      "description": "Stable identifier for the app (e.g. 'dfl-learn-mobile')."
    },
    "app_version": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}-[0-9a-f]{4,40}$",
      "description": "App build identifier in the form YYYY-MM-DD-<git-sha-short>."
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp when this snapshot was generated."
    },
    "tech_stack": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of tech-stack tags (e.g. 'react-native', 'expo', 'powersync')."
    },
    "screens": {
      "type": "array",
      "items": { "$ref": "#/$defs/screen" }
    },
    "flows": {
      "type": "array",
      "items": { "$ref": "#/$defs/flow" }
    },
    "dead_code": {
      "type": "array",
      "items": { "$ref": "#/$defs/deadCodeEntry" }
    }
  },
  "$defs": {
    "screen": {
      "type": "object",
      "required": ["id", "name"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Stable screen identifier (snake_case recommended)."
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable screen name."
        },
        "route": {
          "type": "string",
          "description": "Route / path / deep-link associated with this screen."
        },
        "components": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Component identifiers rendered on this screen."
        },
        "api_calls": {
          "type": "array",
          "items": { "type": "string" },
          "description": "API endpoints or RPC calls invoked from this screen."
        },
        "actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/action" }
        }
      }
    },
    "action": {
      "type": "object",
      "required": ["id", "label"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "next_screen": {
          "type": "string",
          "description": "Screen id the user lands on after this action."
        },
        "side_effect": {
          "type": "string",
          "description": "Free-form description of side effect (mutation, analytics, etc.)."
        }
      }
    },
    "flow": {
      "type": "object",
      "required": ["name", "start", "steps"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "start": {
          "type": "string",
          "minLength": 1,
          "description": "Screen id where the flow starts."
        },
        "steps": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Ordered list of screen ids traversed in this flow."
        },
        "actions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Ordered list of action ids exercised during this flow."
        },
        "tested_by": {
          "type": "array",
          "items": { "type": "string" },
          "description": "References to tests (file paths, test names) that cover this flow."
        }
      }
    },
    "deadCodeEntry": {
      "type": "object",
      "required": ["component", "reason"],
      "additionalProperties": false,
      "properties": {
        "component": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
